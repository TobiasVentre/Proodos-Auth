{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "dist",
    "baseUrl": "..",
    "paths": {
      "@proodos/domain/*": ["Domain/src/*"],
      "@proodos/application/*": ["Application/src/*"],
      "@proodos/infrastructure/*": ["Infrastructure/src/*"],
      "@proodos/api/*": ["API/src/*"]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ]
}
