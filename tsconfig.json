{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@proodos/domain/*": ["Domain/dist/*"],
      "@proodos/application/*": ["Application/dist/*"],
      "@proodos/infrastructure/*": ["Infrastructure/dist/*"],
      "@proodos/api/*": ["API/dist/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true
  }
}


